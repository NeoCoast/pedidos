<div class="max-w-lg mx-auto">
  <h1 class="text-3xl font-display font-bold text-white tracking-tight mb-6"><%= @user.display_name %></h1>
  <div class="glass-card-static p-6">
    <dl class="space-y-4">
      <div>
        <dt class="text-sm font-medium text-slate-500">Nombre</dt>
        <dd class="text-white mt-1"><%= @user.first_name %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-slate-500">Apellido</dt>
        <dd class="text-white mt-1"><%= @user.last_name %></dd>
      </div>
      <% if @user.nickname.present? %>
        <div>
          <dt class="text-sm font-medium text-slate-500">Nickname</dt>
          <dd class="text-white mt-1"><%= @user.nickname %></dd>
        </div>
      <% end %>
    </dl>
  </div>
  <div class="mt-5 flex items-center gap-4">
    <%= link_to "Editar", edit_user_path(@user), class: "btn-ghost" %>
    <%= link_to users_path, class: "inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-amber-400 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Volver
    <% end %>
  </div>
</div>
