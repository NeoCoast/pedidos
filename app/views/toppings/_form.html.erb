<%= form_with model: [restaurant, menu_item, topping], class: "space-y-5" do |f| %>
  <% if topping.errors.any? %>
    <div class="px-4 py-3 rounded-xl border border-red-500/20 bg-red-500/10">
      <ul class="list-disc pl-5 text-sm space-y-1 text-red-400">
        <% topping.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Nombre", class: "block text-sm font-medium text-slate-400 mb-1.5" %>
    <%= f.text_field :name, class: "input-dark" %>
  </div>

  <div>
    <%= f.label :price, "Precio", class: "block text-sm font-medium text-slate-400 mb-1.5" %>
    <%= f.number_field :price, step: 0.01, class: "input-dark" %>
  </div>

  <div class="pt-2">
    <%= f.submit (topping.persisted? ? "Actualizar" : "Crear Topping"), class: "btn-primary w-full justify-center" %>
  </div>
<% end %>
