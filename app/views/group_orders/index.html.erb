<div class="max-w-5xl mx-auto">
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-10">
    <div>
      <h1 class="text-2xl sm:text-3xl font-display font-bold text-white tracking-tight">Pedidos Grupales</h1>
      <p class="text-slate-500 text-sm mt-1">Organiza los pedidos de tu equipo</p>
    </div>
    <% if current_user %>
      <%= link_to new_group_order_path, class: "btn-primary shrink-0 self-start sm:self-auto" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Nuevo Pedido
      <% end %>
    <% end %>
  </div>

  <% if @active_orders.any? %>
    <div class="flex items-center gap-2 mb-5">
      <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
      <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider">Pedidos Activos</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
      <% @active_orders.each do |go| %>
        <%= link_to group_order_path(go), class: "glass-card block p-5 cursor-pointer group" do %>
          <div class="flex justify-between items-start mb-4">
            <h3 class="text-lg font-display font-semibold text-white group-hover:text-amber-400 transition-colors"><%= go.restaurant.name %></h3>
            <span class="inline-flex items-center px-2.5 py-1 text-xs font-semibold rounded-full
              <%= case go.status
                  when 'open' then 'badge-open'
                  when 'closed' then 'badge-closed'
                  when 'ordered' then 'badge-ordered'
                  end %>">
              <%= { 'open' => 'Abierto', 'closed' => 'Cerrado', 'ordered' => 'Pedido', 'delivered' => 'Entregado' }[go.status] %>
            </span>
          </div>
          <div class="space-y-1.5">
            <p class="text-slate-500 text-sm"><%= go.date.strftime("%d/%m/%Y") %></p>
            <p class="text-slate-500 text-sm">Creado por <span class="text-slate-300"><%= go.creator.display_name %></span></p>
          </div>
          <div class="mt-4 pt-4 border-t border-white/[0.06] flex items-center justify-between">
            <p class="text-slate-400 text-sm font-medium"><%= go.individual_orders.size %> pedido(s)</p>
            <svg class="w-4 h-4 text-slate-600 group-hover:text-amber-400 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="glass-card-static p-12 text-center mb-12">
      <div class="w-16 h-16 rounded-2xl bg-white/5 flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      </div>
      <p class="text-slate-500">No hay pedidos grupales activos.</p>
    </div>
  <% end %>

  <% if @delivered_orders.any? %>
    <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-5">Historial</h2>
    <div class="glass-card-static overflow-x-auto">
      <table class="min-w-[500px] w-full table-dark">
        <thead>
          <tr>
            <th>Fecha</th>
            <th>Restaurante</th>
            <th>Creado por</th>
            <th>Estado</th>
            <th class="text-right">Accion</th>
          </tr>
        </thead>
        <tbody>
          <% @delivered_orders.each do |go| %>
            <tr>
              <td class="text-slate-400"><%= go.date.strftime("%d/%m/%Y") %></td>
              <td class="text-white font-medium"><%= go.restaurant.name %></td>
              <td class="text-slate-400"><%= go.creator.display_name %></td>
              <td><span class="badge-delivered inline-flex items-center px-2.5 py-1 text-xs font-semibold rounded-full">Entregado</span></td>
              <td class="text-right"><%= link_to "Ver", group_order_path(go), class: "text-sm font-medium text-amber-400 hover:text-amber-300 transition" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
