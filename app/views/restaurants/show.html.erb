<div class="max-w-4xl mx-auto">
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-8">
    <div>
      <h1 class="text-2xl sm:text-3xl font-display font-bold text-white tracking-tight"><%= @restaurant.name %></h1>
      <% if @restaurant.url.present? %>
        <p class="mt-1"><%= link_to @restaurant.url.gsub(%r{https?://}, '').chomp('/'), @restaurant.url, target: "_blank", class: "text-sm text-slate-500 hover:text-amber-400 transition" %></p>
      <% end %>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to "Editar", edit_restaurant_path(@restaurant), class: "btn-ghost" %>
      <%= link_to restaurants_path, class: "inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-amber-400 transition" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Volver
      <% end %>
    </div>
  </div>

  <div class="flex justify-between items-center mb-5">
    <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider">Items del Menu</h2>
    <%= link_to new_restaurant_menu_item_path(@restaurant), class: "btn-success text-sm py-2 px-4" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Agregar Item
    <% end %>
  </div>

  <% if @menu_items.any? %>
    <div class="space-y-4">
      <% @menu_items.each do |item| %>
        <div class="glass-card-static p-5">
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-3">
            <div>
              <h3 class="text-lg font-display font-semibold text-white"><%= item.name %></h3>
              <p class="text-amber-400 font-bold text-xl mt-1">$<%= number_with_precision(item.price, precision: 2) %></p>
            </div>
            <div class="inline-flex items-center gap-2 shrink-0">
              <%= link_to edit_restaurant_menu_item_path(@restaurant, item), class: "btn-ghost" do %>
                <svg class="w-3.5 h-3.5 sm:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                <span class="hidden sm:inline">Editar</span>
              <% end %>
              <%= button_to restaurant_menu_item_path(@restaurant, item), method: :delete, class: "btn-danger-ghost", data: { turbo_confirm: "¿Estás seguro?" } do %>
                <svg class="w-3.5 h-3.5 sm:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                <span class="hidden sm:inline">Eliminar</span>
              <% end %>
            </div>
          </div>

          <% if item.toppings.any? %>
            <div class="mt-4">
              <p class="text-[0.6875rem] font-semibold text-slate-500 uppercase tracking-wider mb-2">Toppings</p>
              <div class="flex flex-wrap gap-1.5">
                <% item.toppings.each do |topping| %>
                  <span class="tag-topping">
                    <%= topping.name %> <span class="opacity-50">+$<%= number_with_precision(topping.price, precision: 2) %></span>
                    <%= link_to edit_restaurant_menu_item_topping_path(@restaurant, item, topping), class: "opacity-40 hover:opacity-100 transition ml-0.5" do %>
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                    <% end %>
                    <%= button_to restaurant_menu_item_topping_path(@restaurant, item, topping), method: :delete, class: "opacity-40 hover:opacity-100 hover:text-red-400 transition" do %>
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    <% end %>
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>

          <% if item.extras.any? %>
            <div class="mt-4">
              <p class="text-[0.6875rem] font-semibold text-slate-500 uppercase tracking-wider mb-2">Extras</p>
              <div class="flex flex-wrap gap-1.5">
                <% item.extras.each do |extra| %>
                  <span class="tag-extra">
                    <%= extra.name %> <span class="opacity-50">+$<%= number_with_precision(extra.price, precision: 2) %></span>
                    <%= link_to edit_restaurant_menu_item_extra_path(@restaurant, item, extra), class: "opacity-40 hover:opacity-100 transition ml-0.5" do %>
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                    <% end %>
                    <%= button_to restaurant_menu_item_extra_path(@restaurant, item, extra), method: :delete, class: "opacity-40 hover:opacity-100 hover:text-red-400 transition" do %>
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    <% end %>
                  </span>
                <% end %>
              </div>
            </div>
          <% end %>

          <div class="mt-4 pt-3 border-t border-white/[0.06] flex items-center gap-4">
            <%= link_to new_restaurant_menu_item_topping_path(@restaurant, item), class: "inline-flex items-center gap-1 text-xs font-medium text-indigo-400 hover:text-indigo-300 transition" do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
              Agregar Topping
            <% end %>
            <%= link_to new_restaurant_menu_item_extra_path(@restaurant, item), class: "inline-flex items-center gap-1 text-xs font-medium text-amber-400 hover:text-amber-300 transition" do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
              Agregar Extra
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="glass-card-static p-12 text-center">
      <p class="text-slate-500">No hay items en el menu aun.</p>
    </div>
  <% end %>
</div>
