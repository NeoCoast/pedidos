<div class="max-w-lg mx-auto">
  <h1 class="text-3xl font-display font-bold text-white tracking-tight mb-6">Nuevo Restaurante</h1>

  <div class="glass-card-static p-6">
    <%= render "form", restaurant: @restaurant %>
  </div>

  <div class="mt-5">
    <%= link_to restaurants_path, class: "inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-amber-400 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Volver
    <% end %>
  </div>
</div>
