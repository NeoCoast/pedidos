<div class="max-w-3xl mx-auto">
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-10">
    <div>
      <h1 class="text-2xl sm:text-3xl font-display font-bold text-white tracking-tight">Restaurantes</h1>
      <p class="text-slate-500 text-sm mt-1">Gestiona los restaurantes disponibles</p>
    </div>
    <%= link_to new_restaurant_path, class: "btn-primary self-start sm:self-auto shrink-0" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Nuevo Restaurante
    <% end %>
  </div>

  <div class="glass-card-static overflow-x-auto">
    <table class="min-w-[400px] w-full table-dark">
      <thead>
        <tr>
          <th>Nombre</th>
          <th class="w-48 text-right">Acciones</th>
        </tr>
      </thead>
      <tbody>
        <% @restaurants.each do |restaurant| %>
          <tr>
            <td>
              <%= link_to restaurant.name, restaurant, class: "text-white font-medium hover:text-amber-400 transition" %>
            </td>
            <td class="text-right">
              <%= link_to edit_restaurant_path(restaurant), class: "btn-ghost" do %>
                <svg class="w-3.5 h-3.5 sm:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                <span class="hidden sm:inline">Editar</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
