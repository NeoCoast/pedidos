<div class="max-w-lg mx-auto">
  <h1 class="text-3xl font-display font-bold text-white tracking-tight"><%= @menu_item.name %></h1>
  <p class="text-amber-400 font-bold text-2xl mt-2 mb-6">$<%= number_with_precision(@menu_item.price, precision: 2) %></p>

  <div class="glass-card-static p-6 space-y-4">
    <% if @menu_item.toppings.any? %>
      <div>
        <p class="text-[0.6875rem] font-semibold text-slate-500 uppercase tracking-wider mb-2">Toppings</p>
        <div class="flex flex-wrap gap-1.5">
          <% @menu_item.toppings.each do |t| %>
            <span class="tag-topping"><%= t.name %> <span class="opacity-50">+$<%= number_with_precision(t.price, precision: 2) %></span></span>
          <% end %>
        </div>
      </div>
    <% end %>
    <% if @menu_item.extras.any? %>
      <div>
        <p class="text-[0.6875rem] font-semibold text-slate-500 uppercase tracking-wider mb-2">Extras</p>
        <div class="flex flex-wrap gap-1.5">
          <% @menu_item.extras.each do |e| %>
            <span class="tag-extra"><%= e.name %> <span class="opacity-50">+$<%= number_with_precision(e.price, precision: 2) %></span></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-5">
    <%= link_to restaurant_path(@restaurant), class: "inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-amber-400 transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Volver
    <% end %>
  </div>
</div>
